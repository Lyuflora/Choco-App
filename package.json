{
  "name": "dark-diary",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:lan": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "start:tunnel:clear": "expo start --clear --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:headless": "node scripts/run-web-static.js",
    "eas:configure": "npx eas-cli build:configure",
    "eas:build:development:android": "npx eas-cli build --platform android --profile development",
    "eas:build:development:ios": "npx eas-cli build --platform ios --profile development",
    "eas:build:simulator:ios": "npx eas-cli build --platform ios --profile development-simulator",
    "eas:build:device:android": "npx eas-cli build --platform android --profile preview",
    "eas:build:device:ios": "npx eas-cli build --platform ios --profile preview",
    "eas:build:android": "npx eas-cli build --platform android --profile production",
    "eas:build:ios": "npx eas-cli build --platform ios --profile production",
    "eas:submit:android": "npx eas-cli submit --platform android --profile production",
    "eas:submit:ios": "npx eas-cli submit --platform ios --profile production",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "~2.2.0",
    "expo": "~55.0.8",
    "expo-constants": "~55.0.9",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/node": "^25.5.0",
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2",
    "vitest": "^4.1.0"
  },
  "private": true
}
